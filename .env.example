# --- Admin UI auth (session) ---
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=StrongPassword123
SESSION_SECRET=replace-with-random-32-byte-secret

# --- Render API auth ---
RENDER_API_KEY=replace-with-random-key

# --- Render engine tuning ---
# Max concurrent renders; overflow waits then 429 (FRD §16.6).
RENDER_MAX_CONCURRENCY=20
# How long a queued render waits for a slot before 429 (ms).
RENDER_QUEUE_TIMEOUT_MS=15000
# Strict required-layer check: dynamic layer with no value AND no default → 422.
RENDER_STRICT_LAYERS=true

# --- Supabase (Postgres via supabase-js) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Public, browser-safe. Blocked by RLS — cannot access data on its own.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# SECRET, server-only. Bypasses RLS. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=service-role-key-here

# --- Object storage (Supabase Storage) ---
# Public bucket holding templates/generated/assets/fonts. Required on serverless
# (Vercel) — no local disk. Create a PUBLIC bucket with this name.
SUPABASE_STORAGE_BUCKET=media

# --- Drizzle (schema/migration generation only; not used at runtime) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/imagegen

# --- Public base URL (prefixes returned image paths for n8n) ---
PUBLIC_BASE_URL=http://localhost:3000

# --- Image layer remote source allowlist (comma-separated hostnames) ---
IMAGE_SOURCE_ALLOWLIST=cdn.example.com
